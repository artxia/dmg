{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ai-cli-complete-notify",
  "version": "2.8.0",
  "identifier": "com.aicli.complete.notify",
  "build": {
    "beforeBuildCommand": "node node_modules/vite/bin/vite.js build",
    "beforeDevCommand": "node node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist-ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI CLI Complete Notify",
        "width": 1280,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 720,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ai-reminder"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
